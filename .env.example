NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug

PUBLIC_PRODUCT_NAME=Workside Home Seller Assistant
PUBLIC_BRAND_NAME=Workside Software
PUBLIC_SUPPORT_EMAIL=support@workside.software
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_ADMIN_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

MONGODB_URI=mongodb://localhost:27017/workside-home-seller
MONGODB_DB_NAME=workside-home-seller
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

EMAIL_PROVIDER=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=hello@workside.software
OTP_LENGTH=6
OTP_TTL_MINUTES=15

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_DEFAULT=gpt-4.1-mini
OPENAI_MODEL_REASONING=o4-mini
OPENAI_MODEL_VISION=gpt-4.1-mini

STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=

MARKET_DATA_PROVIDER=rentcast
MARKET_DATA_API_KEY=
RENTCAST_API_KEY=
RENTCAST_BASE_URL=https://api.rentcast.io/v1
GOOGLE_MAPS_API_KEY=

EXPO_PUBLIC_API_URL=http://localhost:4000
